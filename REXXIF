/*REXX*/
CALL "TSOCLR"

START:

SAY "WELCOME TO TEMPERATURE CONVERSION PROGRAM"
SAY
SAY "ENTER TEMPERATURE FAHRENHEIT, OR E TO END"

PULL TEMP

IF TEMP = "E" THEN EXIT 0

IF DATATYPE(TEMP, "N") = 0 THEN DO
  SAY "ERROR NOT A NUMBER"
  SIGNAL START
END

IF TEMP < 32 | TEMP > 212 THEN  DO
  SAY "ERROR INVALID INPUT <32 OR >212 "
  SIGNAL START
END

/* WORK HERE LATER*/
CELSIUS = (TEMP - 32) * (5 / 9)
SAY
SAY "RESULT =" CELSIUS
SAY

SIGNAL START
