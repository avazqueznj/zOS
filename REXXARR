/*REXX*/
CALL "TSOCLR" 

START:
SAY
SAY "WELCOME TO GRADES PROGRAM WITH AN ARRAY"
SAY

STUDENT_COUNT = 0
DO FOREVER

 SAY
 SAY "ENTER STUDENTID OR E TO END"
 PULL STUDENTID


 /* PARSE STUDENT */
 IF STUDENTID = "E" THEN LEAVE

 IF STUDENTID = "" THEN DO
  SAY "ERROR EMPTY STUDENTID"
  ITERATE
 END

 MYARRAY.STUDENT_COUNT = STUDENTID
 STUDENT_COUNT = STUDENT_COUNT + 1

END /* LOOP END */

IF STUDENT_COUNT = 0 THEN DO
  SAY "NO DATA ENTERED" 
  EXIT 0
END

SAY
DO I = 0 TO STUDENT_COUNT - 1
 SAY "ELEMENT" I + 1 "IS" MYARRAY.I
END

EXIT 0
