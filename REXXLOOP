/*REXX*/
CALL "TSOCLR"

START:

SAY "WELCOME TO LOOPING PROGRAM"

SAY

SAY "HOW MANY LOOPS ? OR E TO END"
PULL LOOPCOUNT

IF LOOPCOUNT = "E" THEN EXIT 0

IF DATATYPE(LOOPCOUNT, "N") = 0 THEN DO
  SAY "ERROR NOT A NUMBER"
  SIGNAL START
END

IF LOOPCOUNT < 1 | LOOPCOUNT > 100 THEN  DO
  SAY "ERROR INVALID INPUT <1 OR >100 "
  SIGNAL START
END

DO I = 1 TO LOOPCOUNT
 SAY "THIS IS TIME =>" I "THRU LOOP"
END

SAY
SAY "WE WENT " ( I - 1 ) "TIMES THRU THE LOOP"
SAY "WE ARE DONE!"
SAY

SIGNAL START
